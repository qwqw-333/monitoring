# CoreDNS template
# Переменные окружения
#   DOMAIN     - ваш домен, напр. example.duckdns.org
#   SERVER_IP  - IP Traefik/сервера (по умолчанию 127.0.0.1)

.:53 {
    errors
    log
    cache 30
    reload

    health :8080 {
        lameduck 5s
    }
    ready
    prometheus 0.0.0.0:9153

    hosts {
        172.30.0.212 kuma.2dep.duckdns.org
        172.30.0.212 vault.2dep.duckdns.org
        172.30.0.212 traefik-dashboard.2dep.duckdns.org
        172.30.0.212 grafana.2dep.duckdns.org
        172.30.0.212 prometheus.2dep.duckdns.org
        172.30.0.212 ntfy.2dep.duckdns.org
	ttl 60
	fallthrough
    }

    forward . 8.8.8.8 1.1.1.1
}

unet {
	hosts {
		172.30.0.195 kv.sip.unet
		172.30.2.195 lv.sip.unet
