{
  "uid": "freeswitch-overview",
  "title": "FreeSWITCH Overview",
  "description": "FreeSWITCH cluster monitoring via ESL exporter",
  "tags": ["freeswitch", "voip"],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(freeswitch_up{job=\"freeswitch\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "hide": 0,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "title": "Server Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "freeswitch_up{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Active Registrations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "expr": "freeswitch_registrations_active{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Active Channels",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "expr": "freeswitch_channels_active{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Active Calls",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "expr": "freeswitch_calls_active{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Sessions per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "pointSize": 5, "showPoints": "auto", "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "expr": "freeswitch_sps_current{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} current",
          "refId": "A"
        },
        {
          "expr": "freeswitch_sps_peak_5min{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} peak 5m",
          "refId": "B"
        }
      ]
    },

    {
      "title": "Sofia Profiles",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "mappings",
                "value": [
                  { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "RUNNING" } }, "type": "value" }
                ]
              },
              { "id": "custom.align", "value": "center" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "job" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "group" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "__name__" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "instance" },
            "properties": [ { "id": "displayName", "value": "Server" }, { "id": "custom.width", "value": 160 } ]
          },
          {
            "matcher": { "id": "byName", "options": "name" },
            "properties": [ { "id": "displayName", "value": "Profile" }, { "id": "custom.width", "value": 160 } ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [ { "displayName": "Server", "desc": false } ],
        "cellHeight": "sm"
      },
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["lastNotNull"] } },
        { "id": "seriesToColumns", "options": {} }
      ],
      "targets": [
        {
          "expr": "freeswitch_sofia_profile_up{job=\"freeswitch\", instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "title": "Gateways",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "mappings",
                "value": [
                  { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
                ]
              },
              { "id": "custom.align", "value": "center" },
              { "id": "displayName", "value": "Status" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "job" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "group" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "__name__" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "instance" },
            "properties": [ { "id": "displayName", "value": "Server" }, { "id": "custom.width", "value": 140 } ]
          },
          {
            "matcher": { "id": "byName", "options": "name" },
            "properties": [ { "id": "displayName", "value": "Gateway" }, { "id": "custom.width", "value": 250 } ]
          },
          {
            "matcher": { "id": "byName", "options": "profile" },
            "properties": [ { "id": "displayName", "value": "Profile" }, { "id": "custom.width", "value": 120 } ]
          },
          {
            "matcher": { "id": "byName", "options": "proxy" },
            "properties": [ { "id": "displayName", "value": "Proxy" }, { "id": "custom.width", "value": 180 } ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [ { "displayName": "Server", "desc": false } ],
        "cellHeight": "sm"
      },
      "targets": [
        {
          "expr": "freeswitch_gateway_up{job=\"freeswitch\", instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "title": "CPU Idle %",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 20 }, { "color": "green", "value": 50 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "expr": "freeswitch_cpu_idle{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 3600 }, { "color": "green", "value": 86400 } ] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "freeswitch_uptime_seconds{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Gateway Calls In/Out",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "expr": "freeswitch_gateway_calls_in_total{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} {{name}} IN",
          "refId": "A"
        },
        {
          "expr": "freeswitch_gateway_calls_out_total{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} {{name}} OUT",
          "refId": "B"
        }
      ]
    },

    {
      "title": "Gateway Ping Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "expr": "freeswitch_gateway_ping_seconds{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} {{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "title": "Scrape Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "expr": "freeswitch_scrape_duration_seconds{job=\"freeswitch\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ]
}
